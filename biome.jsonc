{
	"files": {
		"includes": ["**", "!dist", "!benchmarks/**/frameworks/*.bundle.js"]
	},
	"linter": {
		"rules": {
			"a11y": {
				"useHtmlLang": "off",
				"useButtonType": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noAssignInExpressions": "off",
				"useIsArray": "off"
			},
			"complexity": {
				"noStaticOnlyClass": "off",
				"noCommaOperator": "off"
			}
		}
	}
}
